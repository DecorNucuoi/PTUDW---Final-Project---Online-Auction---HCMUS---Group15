

<div class="card">
  <h5 class="card-header">
    <i class="bi bi-person-plus"></i>
    User Profile
  </h5>
  <div class="card-body">
    
    {{#if err_message}}
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{err_message}}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    {{/if}}

    {{#if success_message}}
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        {{success_message}}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    {{/if}}

    <form method="post">
      <!-- Email -->
      <div class="row mb-3">
        <label for="email" class="col-sm-3 col-form-label">
          <i class="bi bi-envelope"></i>
          Email
        </label>
        <div class="col-sm-9">
          <input type="hidden" class="form-control" id="id" name="id" readonly value="{{user.id}}">
          <input type="email" class="form-control" id="email" name="email" placeholder="Enter email address" value="{{user.email}}">
        </div>
      </div>

      <!-- Full Name -->
      <div class="row mb-3">
        <label for="full_name" class="col-sm-3 col-form-label">
          <i class="bi bi-card-heading"></i>
          Full Name
        </label>
        <div class="col-sm-9">
          <input type="text" class="form-control" id="full_name" name="full_name" placeholder="Enter full name" value="{{user.full_name}}">
        </div>
      </div>

      <!-- Update Button -->
      <div class="row">
        <div class="col-sm-9 offset-sm-3">
          <button type="submit" class="btn btn-outline-primary btn-lg w-100">
            <i class="bi bi-person-check"></i>
            Update
          </button>
        </div>
      </div>
    </form>
  </div>
</div>